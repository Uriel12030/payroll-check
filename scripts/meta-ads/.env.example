# Meta Ads Campaign Launcher — Environment Variables
# Copy to .env and fill in your values.

# Long-lived token with permissions: ads_management, pages_read_engagement, leads_retrieval
# Generate at: https://developers.facebook.com/tools/explorer/
META_ACCESS_TOKEN=

# Ad Account ID (format: act_XXXXXXXXX)
META_AD_ACCOUNT_ID=act_XXX

# Facebook Page ID linked to the ad account
META_PAGE_ID=

# (Optional) Instagram account ID for cross-placement
META_INSTAGRAM_ID=

# (Optional) Pixel ID to associate with ads
META_PIXEL_ID=

# Landing page URLs
LANDING_URL=https://payroll-check.vercel.app/
THANK_YOU_URL=https://payroll-check.vercel.app/thank-you
PRIVACY_URL=https://payroll-check.vercel.app/privacy
